
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GeoArchivo | Catálogo Universitario</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(180deg, #d8e2ec 0%, #e7eef7 40%, #f1f5f9 100%);
            min-height: 100vh;
            color: #0f172a;
            background-attachment: fixed;
        }
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 16%),
                              radial-gradient(circle at bottom right, rgba(15, 23, 42, 0.08), transparent 24%);
            pointer-events: none;
            z-index: -1;
        }
        .glass-effect {
            background: rgba(248, 250, 252, 0.92);
            backdrop-filter: blur(16px);
            border-color: rgba(148, 163, 184, 0.22);
        }
        body.dark-mode .glass-effect {
            background: rgba(15, 23, 42, 0.82);
            border-color: rgba(148, 163, 184, 0.18);
        }
        .specimen-card {
            transform: translateY(0);
            animation: fadeInUp 0.55s ease forwards;
        }
        .specimen-card:hover img { transform: scale(1.05); }
        .table-row:hover { background-color: rgba(96, 165, 250, 0.1); }
        .modal-backdrop { background: rgba(15, 23, 42, 0.82); }
        .modal-backdrop > div { animation: popIn 0.32s ease-out both; }
        button, input, select {
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
        }
        button:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12);
        }
        button:active {
            transform: translateY(0) scale(0.98);
        }
        input:hover, select:hover,
        input:focus, select:focus {
            transform: translateY(-0.5px);
            box-shadow: 0 10px 24px rgba(59, 130, 246, 0.14);
        }
        .fade-highlight {
            animation: pulseHighlight 2.2s ease-in-out;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(18px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes popIn {
            from { opacity: 0; transform: translateY(16px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes pulseHighlight {
            0%, 100% { box-shadow: 0 0 0 0 rgba(96, 165, 250, 0); }
            50% { box-shadow: 0 0 0 16px rgba(96, 165, 250, 0.08); }
        }
        body.dark-mode {
            background: linear-gradient(180deg, #020617 0%, #091522 40%, #112a42 100%);
            color: #e2e8f0;
        }
        body.dark-mode .text-slate-900 { color: #e2e8f0 !important; }
        body.dark-mode .bg-white { background-color: rgba(15, 23, 42, 0.9) !important; }
        body.dark-mode .bg-slate-50 { background-color: rgba(15, 23, 42, 0.6) !important; }
        body.dark-mode .border-slate-200 { border-color: rgba(148, 163, 184, 0.16) !important; }
        body.dark-mode .border-slate-100 { border-color: rgba(148, 163, 184, 0.12) !important; }
        body.dark-mode .text-slate-400, body.dark-mode .text-slate-500, body.dark-mode .text-slate-600, body.dark-mode .text-slate-700 {
            color: #e2e8f0 !important;
        }
        body.dark-mode .shadow-sm { box-shadow: 0 12px 40px rgba(0, 0, 0, 0.18); }
        body.dark-mode .bg-blue-600 { background-color: #2563eb !important; }
        body.dark-mode .bg-blue-700 { background-color: #1d4ed8 !important; }
        body.dark-mode .bg-slate-900 { background-color: #0f172a !important; }
        body.dark-mode .text-white { color: #f8fafc !important; }
    </style>
</head>
<body class="text-slate-900">

    <nav id="pageHeader" class="sticky top-0 z-50 glass-effect border-b border-slate-200 py-4 px-6 shadow-sm">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row justify-between gap-4 items-start lg:items-center">
            <div class="flex items-center gap-3">
                <div class="rounded-2xl bg-blue-600 p-3 text-white shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 64 64" aria-hidden="true">
                        <circle cx="32" cy="32" r="28" fill="none" stroke="currentColor" stroke-width="4"/>
                        <path d="M32 6v52" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                        <path d="M10 32h44" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                        <path d="M20 16c8 4 16 4 24 0" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                        <path d="M20 48c8-4 16-4 24 0" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                        <path d="M43 24l13-13 5 5-13 13" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M41 26l-7 15 6 6 15-7" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div>
                    <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Ingenieria Mecatronica</p>
                    <h1 class="text-2xl font-bold tracking-tight text-slate-900">GeoArchivo</h1>
                    <p class="text-sm text-slate-500">Catálogo universitario de muestras geológicas y moluscos.</p>
                </div>
            </div>
            <div class="flex gap-3 flex-wrap items-center">
                <button id="openAddBtn" class="rounded-2xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 transition">Agregar registro</button>
                <button id="themeToggleBtn" class="rounded-2xl border border-slate-300 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100 transition">Modo oscuro</button>
                <button type="button" onclick="printSelectedSpecimen()" class="rounded-2xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition">Imprimir ficha</button>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto p-6 md:p-10">
        <section class="mb-8 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="grid gap-4 lg:grid-cols-[1.5fr_auto] items-end">
                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-400 mb-2">Buscar</label>
                        <input id="mainSearch" type="text" placeholder="Ej: Ammonites, Pizarra, Cordillera" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-400 mb-2">Sustrato</label>
                        <select id="typeFilter" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
                            <option value="all">Todos</option>
                            <option value="Caliza">Caliza</option>
                            <option value="Granito">Granito / Ígnea</option>
                            <option value="Pizarra">Pizarra / Esquisto</option>
                            <option value="Fósil">Fósil</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-400 mb-2">Categoría</label>
                        <select id="categoryFilter" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
                            <option value="all">Todos</option>
                            <option value="Molusco">Molusco</option>
                            <option value="Roca">Roca</option>
                            <option value="Mineral">Mineral</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-400 mb-2">Color</label>
                        <input id="colorFilter" type="text" placeholder="Ej: Marrón, Gris, Rosa" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-400 mb-2">Edad</label>
                        <input id="ageFilter" type="text" placeholder="Ej: Jurásico, Precámbrico" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
                    </div>
                    <div class="flex flex-col justify-end gap-2 xl:col-span-2">
                        <p class="text-sm text-slate-500">Resultados encontrados:</p>
                        <p id="statsCount" class="text-lg font-semibold text-slate-900">Cargando catálogo...</p>
                    </div>
                </div>
                <button id="toggleViewBtn" class="rounded-2xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 transition">Ver tabla</button>
            </div>
            <div class="mt-6 flex flex-col gap-3 rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm md:flex-row md:justify-between md:items-center">
                <div class="flex flex-wrap gap-3">
                    <button id="clearFiltersBtn" class="rounded-2xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100 transition">Limpiar filtros</button>
                    <button id="exportBtn" class="rounded-2xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition">Exportar JSON</button>
                    <button id="importBtn" class="rounded-2xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 transition">Importar JSON</button>
                    <button id="resetBtn" class="rounded-2xl bg-rose-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-700 transition">Reiniciar catálogo</button>
                </div>
                <div class="flex flex-wrap items-center gap-3">
                    <label class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Ordenar:</label>
                    <select id="sortFilter" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
                        <option value="name">Nombre</option>
                        <option value="code">Código</option>
                        <option value="age">Edad</option>
                        <option value="category">Categoría</option>
                        <option value="newest">Más recientes</option>
                        <option value="oldest">Más antiguos</option>
                    </select>
                </div>
            </div>
        </section>

        <section class="grid gap-8 lg:grid-cols-[1.9fr_1fr]">
            <div class="space-y-6">
                <div id="resultsGrid" class="grid grid-cols-1 gap-6 lg:grid-cols-2 xl:grid-cols-3"></div>

                <div id="resultsTableWrapper" class="hidden overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
                    <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
                        <p class="text-sm font-semibold text-slate-700">Tabla de muestras</p>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full text-left text-sm text-slate-600">
                            <thead class="bg-slate-100 text-slate-500 uppercase text-[11px] tracking-[.2em]">
                                <tr>
                                    <th class="px-4 py-3">Código</th>
                                    <th class="px-4 py-3">Nombre</th>
                                    <th class="px-4 py-3">Sustrato</th>
                                    <th class="px-4 py-3">Color</th>
                                    <th class="px-4 py-3">Edad</th>
                                    <th class="px-4 py-3">Ver</th>
                                    <th class="px-4 py-3">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="resultsTableBody"></tbody>
                        </table>
                    </div>
                </div>

                <div id="emptyState" class="hidden rounded-3xl border border-slate-200 bg-white p-10 text-center shadow-sm">
                    <p class="text-slate-400">No se encontraron especímenes con esos criterios.</p>
                </div>
            </div>

            <aside class="space-y-6">
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                    <div class="mb-4 flex items-center justify-between gap-4">
                        <div>
                            <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Ficha técnica</p>
                            <h2 id="detailName" class="mt-2 text-2xl font-semibold text-slate-900">Selecciona una muestra</h2>
                        </div>
                        <span id="detailTag" class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600"></span>
                    </div>
                    <div id="detailPanel" class="space-y-5 text-slate-600">
                        <div class="rounded-3xl overflow-hidden border border-slate-200 bg-slate-50">
                            <img id="detailImage" src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=900" alt="Muestra" class="h-64 w-full object-cover">
                        </div>
                        <div class="grid gap-3 sm:grid-cols-2">
                            <div class="rounded-3xl bg-slate-50 p-4">
                                <p class="text-[11px] uppercase tracking-[0.25em] text-slate-400">Código</p>
                                <p id="detailCode" class="mt-2 font-semibold text-slate-800">-</p>
                            </div>
                            <div class="rounded-3xl bg-slate-50 p-4">
                                <p class="text-[11px] uppercase tracking-[0.25em] text-slate-400">Tipo</p>
                                <p id="detailType" class="mt-2 font-semibold text-slate-800">-</p>
                            </div>
                            <div class="rounded-3xl bg-slate-50 p-4">
                                <p class="text-[11px] uppercase tracking-[0.25em] text-slate-400">Color</p>
                                <p id="detailColor" class="mt-2 font-semibold text-slate-800">-</p>
                            </div>
                            <div class="rounded-3xl bg-slate-50 p-4">
                                <p class="text-[11px] uppercase tracking-[0.25em] text-slate-400">Edad</p>
                                <p id="detailAge" class="mt-2 font-semibold text-slate-800">-</p>
                            </div>
                            <div class="sm:col-span-2 rounded-3xl bg-slate-50 p-4">
                                <p class="text-[11px] uppercase tracking-[0.25em] text-slate-400">Procedencia</p>
                                <p id="detailLocality" class="mt-2 font-semibold text-slate-800">-</p>
                            </div>
                            <div class="sm:col-span-2 rounded-3xl bg-slate-50 p-4">
                                <p class="text-[11px] uppercase tracking-[0.25em] text-slate-400">Formación</p>
                                <p id="detailFormation" class="mt-2 font-semibold text-slate-800">-</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                    <h3 class="text-sm uppercase tracking-[0.25em] text-slate-400">Descripción</h3>
                    <p id="detailDesc" class="mt-3 text-sm leading-6 text-slate-600">Selecciona una muestra de la lista para ver la ficha completa aquí.</p>
                </div>
            </aside>
        </section>
    </main>
    <input type="file" id="importFileInput" accept="application/json" class="hidden">
    <div id="toast" class="fixed bottom-6 right-6 hidden rounded-3xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-xl"></div>

    <div id="modalBackdrop" class="fixed inset-0 hidden items-center justify-center modal-backdrop">
        <div class="mx-4 w-full max-w-3xl rounded-[32px] bg-white p-6 shadow-2xl ring-1 ring-slate-300 max-h-[calc(100vh-80px)] overflow-hidden">
            <div class="flex items-center justify-between gap-4 pb-4 border-b border-slate-200">
                <div>
                    <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Nuevo registro</p>
                    <h2 id="modalTitle" class="text-xl font-semibold text-slate-900">Agregar muestra al catálogo</h2>
                </div>
                <button id="closeModalBtn" class="rounded-full bg-slate-100 p-3 text-slate-600 hover:bg-slate-200">✕</button>
            </div>
            <form id="addForm" class="grid gap-4 py-6 max-h-[60vh] overflow-y-auto pr-2">
                <div class="grid gap-4 sm:grid-cols-2">
                    <label class="space-y-2 text-sm text-slate-700"><span>Código de catálogo</span><input id="inputCode" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="UNIV-MOL-001"></label>
                    <label class="space-y-2 text-sm text-slate-700"><span>Nombre</span><input id="inputName" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="Ammonites común"></label>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                    <label class="space-y-2 text-sm text-slate-700"><span>Tipo</span><select id="inputType" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none"><option value="Fósil">Fósil</option><option value="Caliza">Caliza</option><option value="Granito">Granito</option><option value="Pizarra">Pizarra</option></select></label>
                    <label class="space-y-2 text-sm text-slate-700"><span>Categoría</span><select id="inputCategory" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none"><option value="Molusco">Molusco</option><option value="Roca">Roca</option><option value="Mineral">Mineral</option></select></label>
                </div>
                <div class="grid gap-4 sm:grid-cols-3">
                    <label class="space-y-2 text-sm text-slate-700"><span>Color</span><input id="inputColor" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="Marrón ocre"></label>
                    <label class="space-y-2 text-sm text-slate-700"><span>Tamaño</span><input id="inputSize" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="120 mm"></label>
                    <label class="space-y-2 text-sm text-slate-700"><span>Peso</span><input id="inputWeight" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="340 g"></label>
                </div>
                <div class="grid gap-4 sm:grid-cols-3">
                    <label class="space-y-2 text-sm text-slate-700"><span>Dureza (Mohs)</span><input id="inputHardness" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="3.5"></label>
                    <label class="space-y-2 text-sm text-slate-700"><span>Edad geológica</span><input id="inputAge" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="Jurásico"></label>
                    <label class="space-y-2 text-sm text-slate-700"><span>Formación</span><input id="inputFormation" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="Formación Arcabuco"></label>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                    <label class="space-y-2 text-sm text-slate-700"><span>Procedencia</span><input id="inputLocality" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="Cordillera Oriental, Boyacá"></label>
                    <label class="space-y-2 text-sm text-slate-700"><span>Imagen URL</span><input id="inputImage" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="https://..." value="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=900"></label>
                </div>
                <label class="space-y-2 text-sm text-slate-700"><span>Descripción</span><textarea id="inputDesc" rows="4" class="w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none" placeholder="Descripción breve de la muestra"></textarea></label>
                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" id="cancelAddBtn" class="rounded-2xl bg-slate-100 px-5 py-3 font-semibold text-slate-700 hover:bg-slate-200 transition">Cancelar</button>
                    <button type="submit" id="saveBtn" class="rounded-2xl bg-blue-600 px-5 py-3 font-semibold text-white hover:bg-blue-700 transition">Guardar muestra</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const initialDataset = [
            {
                id: 1,
                code: 'UNIV-MOL-001',
                name: 'Ammonites común',
                category: 'Molusco',
                type: 'Fósil',
                color: 'Marrón ocre',
                size: '120 mm',
                weight: '340 g',
                hardness: '3.5',
                locality: 'Cordillera Oriental, Boyacá, Colombia',
                age: 'Jurásico',
                formation: 'Formación Arcabuco',
                habitat: 'Depósito sedimentario marino',
                desc: 'Espiral bien conservada con costillas marcadas, ejemplar típico de la formación.',
                img: 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=900'
            },
            {
                id: 2,
                code: 'UNIV-ROC-012',
                name: 'Caliza grisácea',
                category: 'Roca',
                type: 'Caliza',
                color: 'Gris claro',
                size: '210 mm',
                weight: '850 g',
                hardness: '4',
                locality: 'Cundinamarca, Colombia',
                age: 'Cretácico',
                formation: 'Formación Guadalupe',
                habitat: 'Afloramiento kárstico',
                desc: 'Roca sedimentaria con fósiles fragmentados y capas bien definidas.',
                img: 'https://images.unsplash.com/photo-1518873890627-d4ea22f4f14f?auto=format&fit=crop&q=80&w=900'
            },
            {
                id: 3,
                code: 'UNIV-MIN-005',
                name: 'Cuarzo rosado',
                category: 'Mineral',
                type: 'Mineral',
                color: 'Rosa pálido',
                size: '90 mm',
                weight: '180 g',
                hardness: '7',
                locality: 'Santander, Colombia',
                age: 'Precámbrico',
                formation: 'Veta pegmatítica',
                habitat: 'Grieta pegmatítica',
                desc: 'Cristales translúcidos con brillo vítreo, puro y bien formado.',
                img: 'https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&q=80&w=900'
            }
        ];

        const storageKey = 'geoArchivoSamples';
        function loadDataset() {
            try {
                const raw = localStorage.getItem(storageKey);
                if (!raw) return initialDataset.slice();
                const parsed = JSON.parse(raw);
                return Array.isArray(parsed) ? parsed : initialDataset.slice();
            } catch (error) {
                localStorage.removeItem(storageKey);
                return initialDataset.slice();
            }
        }
        const dataset = loadDataset();
        let filteredData = [...dataset];
        let currentView = 'cards';
        let selectedSpecimenId = dataset.length ? dataset[0].id : null;
        let editingSpecimenId = null;

        const resultsGrid = document.getElementById('resultsGrid');
        const resultsTableWrapper = document.getElementById('resultsTableWrapper');
        const resultsTableBody = document.getElementById('resultsTableBody');
        const emptyState = document.getElementById('emptyState');
        const statsCount = document.getElementById('statsCount');
        const detailName = document.getElementById('detailName');
        const detailTag = document.getElementById('detailTag');
        const detailImage = document.getElementById('detailImage');
        const detailCode = document.getElementById('detailCode');
        const detailType = document.getElementById('detailType');
        const detailColor = document.getElementById('detailColor');
        const detailAge = document.getElementById('detailAge');
        const detailLocality = document.getElementById('detailLocality');
        const detailFormation = document.getElementById('detailFormation');
        const detailDesc = document.getElementById('detailDesc');
        const detailPanel = document.getElementById('detailPanel');
        const openAddBtn = document.getElementById('openAddBtn');
        const themeToggleBtn = document.getElementById('themeToggleBtn');
        const modalBackdrop = document.getElementById('modalBackdrop');
        const closeModalBtn = document.getElementById('closeModalBtn');
        const cancelAddBtn = document.getElementById('cancelAddBtn');
        const addForm = document.getElementById('addForm');
        const modalTitle = document.getElementById('modalTitle');
        const saveBtn = document.getElementById('saveBtn');
        const mainSearch = document.getElementById('mainSearch');
        const typeFilter = document.getElementById('typeFilter');
        const categoryFilter = document.getElementById('categoryFilter');
        const colorFilter = document.getElementById('colorFilter');
        const ageFilter = document.getElementById('ageFilter');
        const sortFilter = document.getElementById('sortFilter');
        const clearFiltersBtn = document.getElementById('clearFiltersBtn');
        const exportBtn = document.getElementById('exportBtn');
        const importBtn = document.getElementById('importBtn');
        const resetBtn = document.getElementById('resetBtn');
        const importFileInput = document.getElementById('importFileInput');
        const toast = document.getElementById('toast');
        const toggleViewBtn = document.getElementById('toggleViewBtn');
        const pageHeader = document.getElementById('pageHeader');
        const themeStorageKey = 'geoArchivoTheme';

        function saveDataset() {
            localStorage.setItem(storageKey, JSON.stringify(dataset));
        }

        function showToast(message, variant = 'info') {
            toast.textContent = message;
            toast.className = 'fixed bottom-6 right-6 rounded-3xl px-5 py-3 text-sm font-semibold shadow-xl transition-opacity';
            toast.classList.add(variant === 'error' ? 'bg-rose-600' : 'bg-slate-900');
            toast.classList.remove('hidden');
            toast.style.opacity = '1';
            clearTimeout(window.toastTimer);
            window.toastTimer = setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.classList.add('hidden'), 250);
            }, 2400);
        }

        function applySort(data) {
            const sortBy = sortFilter.value;
            return [...data].sort((a, b) => {
                if (sortBy === 'newest') return b.id - a.id;
                if (sortBy === 'oldest') return a.id - b.id;
                if (sortBy === 'age') return (a.age || '').localeCompare(b.age || '', 'es', { numeric: true });
                return (a[sortBy] || '').toString().localeCompare((b[sortBy] || '').toString(), 'es', { numeric: true });
            });
        }

        function clearFilters() {
            mainSearch.value = '';
            typeFilter.value = 'all';
            categoryFilter.value = 'all';
            colorFilter.value = '';
            ageFilter.value = '';
            sortFilter.value = 'name';
            filterData();
            showToast('Filtros limpiados correctamente.');
        }

        function exportData() {
            const blob = new Blob([JSON.stringify(dataset, null, 2)], { type: 'application/json' });
            const href = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = href;
            link.download = 'geoarchivo-catalogo.json';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(href);
            showToast('Catálogo exportado como JSON.');
        }

        function importData() {
            importFileInput.value = '';
            importFileInput.click();
        }

        function printSelectedSpecimen() {
            const specimen = dataset.find(item => item.id === selectedSpecimenId);
            if (!specimen) {
                showToast('Selecciona primero la muestra que quieres imprimir.', 'error');
                return;
            }

            const printHTML = `
                <!DOCTYPE html>
                <html lang="es">
                <head>
                    <meta charset="UTF-8">
                    <meta name="viewport" content="width=device-width, initial-scale=1.0">
                    <title>Ficha de ${specimen.name}</title>
                    <style>
                        body { margin: 0; padding: 24px; font-family: 'Plus Jakarta Sans', sans-serif; background: #f8fafc; color: #0f172a; }
                        .card { max-width: 900px; margin: auto; border: 1px solid #cbd5e1; border-radius: 28px; background: white; padding: 28px; box-shadow: 0 28px 60px rgba(15, 23, 42, 0.12); }
                        .hero { display: flex; flex-wrap: wrap; gap: 24px; align-items: flex-start; }
                        .hero img { width: 100%; max-width: 360px; border-radius: 24px; object-fit: cover; }
                        .info { flex: 1; min-width: 260px; }
                        .info h1 { margin: 0; font-size: 2.2rem; line-height: 1.1; }
                        .info p { margin: 8px 0; color: #475569; }
                        .badge { display: inline-block; margin-top: 12px; padding: 10px 16px; border-radius: 999px; background: #e2e8f0; color: #0f172a; font-size: 0.85rem; letter-spacing: 0.08em; text-transform: uppercase; }
                        .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; margin-top: 28px; }
                        .field { padding: 18px 20px; border: 1px solid #e2e8f0; border-radius: 22px; background: #f8fafc; }
                        .field strong { display: block; margin-bottom: 10px; font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: #64748b; }
                        .description { margin-top: 28px; line-height: 1.8; color: #334155; }
                        @media print { body { background: white; } .card { box-shadow: none; border: none; } }
                    </style>
                </head>
                <body>
                    <article class="card">
                        <div class="hero">
                            <img src="${specimen.img}" alt="${specimen.name}">
                            <div class="info">
                                <span class="badge">${specimen.category}</span>
                                <h1>${specimen.name}</h1>
                                <p><strong>Código:</strong> ${specimen.code}</p>
                                <p><strong>Tipo:</strong> ${specimen.type}</p>
                                <p><strong>Edad:</strong> ${specimen.age}</p>
                                <p><strong>Color:</strong> ${specimen.color}</p>
                                <p><strong>Procedencia:</strong> ${specimen.locality}</p>
                                <p><strong>Formación:</strong> ${specimen.formation}</p>
                            </div>
                        </div>
                        <div class="grid">
                            <div class="field"><strong>Tamaño</strong>${specimen.size || 'Sin dato'}</div>
                            <div class="field"><strong>Peso</strong>${specimen.weight || 'Sin dato'}</div>
                            <div class="field"><strong>Dureza (Mohs)</strong>${specimen.hardness || 'Sin dato'}</div>
                            <div class="field"><strong>Habitat</strong>${specimen.habitat || 'Sin dato'}</div>
                        </div>
                        <div class="description">
                            <h2>Descripción</h2>
                            <p>${specimen.desc}</p>
                        </div>
                    </article>
                </body>
                </html>
            `;

            const printWindow = window.open('', '_blank', 'width=900,height=700');
            if (!printWindow) {
                showToast('No se pudo abrir la ventana de impresión.', 'error');
                return;
            }
            printWindow.document.write(printHTML);
            printWindow.document.close();
            printWindow.focus();
            printWindow.onload = () => {
                printWindow.print();
                printWindow.onafterprint = () => printWindow.close();
            };
        }

        function handleImportFile(event) {
            const file = event.target.files?.[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = () => {
                try {
                    const parsed = JSON.parse(reader.result);
                    if (!Array.isArray(parsed)) throw new Error('Formato inválido');
                    dataset.length = 0;
                    dataset.push(...parsed);
                    saveDataset();
                    filterData();
                    showToast('Catálogo importado con éxito.');
                } catch (error) {
                    showToast('Error al importar el archivo JSON.', 'error');
                }
            };
            reader.readAsText(file);
        }

        function resetCatalog() {
            if (!confirm('¿Quieres reiniciar el catálogo y restaurar los datos originales?')) return;
            dataset.length = 0;
            dataset.push(...initialDataset.map(item => ({ ...item })));
            saveDataset();
            clearFilters();
            showToast('Catálogo restablecido a los datos iniciales.');
        }

        function setDetail(specimen) {
            if (!specimen) {
                detailName.textContent = 'Selecciona una muestra';
                detailTag.textContent = '';
                detailImage.src = 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=900';
                detailCode.textContent = '-';
                detailType.textContent = '-';
                detailColor.textContent = '-';
                detailAge.textContent = '-';
                detailLocality.textContent = '-';
                detailFormation.textContent = '-';
                detailDesc.textContent = 'Selecciona una muestra de la lista para ver la ficha completa aquí.';
                return;
            }
            detailName.textContent = specimen.name;
            detailTag.textContent = specimen.category;
            detailImage.src = specimen.img || 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=900';
            detailCode.textContent = specimen.code;
            detailType.textContent = specimen.type;
            detailColor.textContent = specimen.color;
            detailAge.textContent = specimen.age;
            detailLocality.textContent = specimen.locality;
            detailFormation.textContent = specimen.formation;
            detailDesc.textContent = specimen.desc;
            detailPanel.classList.add('fade-highlight');
            window.setTimeout(() => detailPanel.classList.remove('fade-highlight'), 850);
        }

        function render(data) {
            resultsGrid.innerHTML = '';
            resultsTableBody.innerHTML = '';
            statsCount.textContent = `${data.length} especímenes encontrados`;
            emptyState.classList.toggle('hidden', data.length > 0);

            data.forEach(specimen => {
                resultsGrid.innerHTML += `
                    <article class="specimen-card group overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-sm transition hover:shadow-xl">
                        <div class="relative h-56 overflow-hidden bg-slate-100">
                            <img src="${specimen.img}" alt="${specimen.name}" class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
                            <div class="absolute left-4 top-4 rounded-full bg-slate-900/90 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] text-white shadow-sm">${specimen.type}</div>
                        </div>
                        <div class="p-5">
                            <p class="text-xs uppercase tracking-[0.2em] text-slate-400">${specimen.code}</p>
                            <h3 class="mt-3 text-xl font-semibold text-slate-900">${specimen.name}</h3>
                            <p class="mt-2 text-sm text-slate-600">${specimen.locality}</p>
                            <p class="mt-4 text-sm leading-6 text-slate-500">${specimen.desc}</p>
                            <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                <div class="flex flex-wrap gap-2">
                                    <button type="button" onclick="showSpecimen(${specimen.id})" class="rounded-2xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition">Ver ficha</button>
                                    <button type="button" onclick="openEditModal(${specimen.id}, event)" class="rounded-2xl bg-amber-500 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-600 transition">Editar</button>
                                    <button type="button" onclick="deleteSpecimen(${specimen.id}, event)" class="rounded-2xl bg-rose-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-700 transition">Borrar</button>
                                </div>
                                <span class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-slate-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4"><path d="M10 2a7 7 0 100 14 7 7 0 000-14zm0 2a5 5 0 110 10 5 5 0 010-10z"/></svg>
                                    ${specimen.age}
                                </span>
                            </div>
                        </div>
                    </article>
                `;
                resultsTableBody.innerHTML += `
                    <tr class="table-row cursor-pointer border-b border-slate-100 transition duration-150 hover:bg-slate-50" onclick="showSpecimen(${specimen.id})">
                        <td class="px-4 py-4 font-semibold text-slate-800">${specimen.code}</td>
                        <td class="px-4 py-4 text-slate-700">${specimen.name}</td>
                        <td class="px-4 py-4">${specimen.type}</td>
                        <td class="px-4 py-4">${specimen.color}</td>
                        <td class="px-4 py-4">${specimen.age}</td>
                        <td class="px-4 py-4"><span class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Abrir</span></td>
                        <td class="px-4 py-4">
                            <div class="flex flex-wrap gap-2 items-center">
                                <button type="button" onclick="openEditModal(${specimen.id}, event)" class="rounded-2xl bg-amber-500 px-3 py-1 text-xs font-semibold text-white hover:bg-amber-600 transition">Editar</button>
                                <button type="button" onclick="deleteSpecimen(${specimen.id}, event)" class="rounded-2xl bg-rose-600 px-3 py-1 text-xs font-semibold text-white hover:bg-rose-700 transition">Borrar</button>
                            </div>
                        </td>
                    </tr>
                `;
            });

            if (selectedSpecimenId && data.some(item => item.id === selectedSpecimenId)) {
                setDetail(data.find(item => item.id === selectedSpecimenId));
            } else if (data.length) {
                setDetail(data[0]);
            } else {
                setDetail(null);
            }
            updateView();
        }

        function updateView() {
            if (currentView === 'table') {
                resultsGrid.classList.add('hidden');
                resultsTableWrapper.classList.remove('hidden');
                toggleViewBtn.textContent = 'Ver tarjetas';
            } else {
                resultsGrid.classList.remove('hidden');
                resultsTableWrapper.classList.add('hidden');
                toggleViewBtn.textContent = 'Ver tabla';
            }
        }

        function buildSearchText(specimen) {
            return [specimen.code, specimen.name, specimen.category, specimen.type, specimen.color, specimen.age, specimen.locality, specimen.formation, specimen.desc, specimen.habitat]
                .filter(Boolean)
                .join(' ')
                .toLowerCase();
        }

        let isDarkMode = localStorage.getItem(themeStorageKey) === 'dark';

        function applyTheme() {
            document.body.classList.toggle('dark-mode', isDarkMode);
            themeToggleBtn.textContent = isDarkMode ? 'Modo claro' : 'Modo oscuro';
            themeToggleBtn.classList.toggle('bg-slate-900', isDarkMode);
            themeToggleBtn.classList.toggle('text-white', isDarkMode);
            themeToggleBtn.classList.toggle('border-slate-700', isDarkMode);
            themeToggleBtn.classList.toggle('border-slate-300', !isDarkMode);
            themeToggleBtn.classList.toggle('bg-slate-50', !isDarkMode);
            themeToggleBtn.classList.toggle('text-slate-700', !isDarkMode);
        }

        function toggleTheme() {
            isDarkMode = !isDarkMode;
            localStorage.setItem(themeStorageKey, isDarkMode ? 'dark' : 'light');
            applyTheme();
        }

        function filterData() {
            const query = mainSearch.value.trim().toLowerCase();
            const type = typeFilter.value;
            const category = categoryFilter.value;
            const color = colorFilter.value.trim().toLowerCase();
            const age = ageFilter.value.trim().toLowerCase();

            filteredData = dataset.filter(specimen => {
                const matchSearch = !query || buildSearchText(specimen).includes(query);
                const matchType = type === 'all' || specimen.type === type;
                const matchCategory = category === 'all' || specimen.category === category;
                const matchColor = !color || (specimen.color && specimen.color.toLowerCase().includes(color));
                const matchAge = !age || (specimen.age && specimen.age.toLowerCase().includes(age));
                return matchSearch && matchType && matchCategory && matchColor && matchAge;
            });

            filteredData = applySort(filteredData);

            if (!filteredData.some(item => item.id === selectedSpecimenId)) {
                selectedSpecimenId = filteredData.length ? filteredData[0].id : null;
            }

            render(filteredData);
        }

        function showSpecimen(id) {
            const specimen = dataset.find(item => item.id === id);
            if (!specimen) return;
            selectedSpecimenId = specimen.id;
            setDetail(specimen);
        }

        function closeModal() {
            modalBackdrop.classList.add('hidden');
            if (pageHeader) pageHeader.classList.remove('hidden');
            document.body.classList.remove('overflow-hidden');
            addForm.reset();
            editingSpecimenId = null;
            modalTitle.textContent = 'Agregar muestra al catálogo';
            saveBtn.textContent = 'Guardar muestra';
            document.getElementById('inputImage').value = 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=900';
        }

        function openModal(specimen = null) {
            if (specimen) {
                editingSpecimenId = specimen.id;
                modalTitle.textContent = 'Editar muestra';
                saveBtn.textContent = 'Guardar cambios';
                document.getElementById('inputCode').value = specimen.code;
                document.getElementById('inputName').value = specimen.name;
                document.getElementById('inputType').value = specimen.type;
                document.getElementById('inputCategory').value = specimen.category;
                document.getElementById('inputColor').value = specimen.color;
                document.getElementById('inputSize').value = specimen.size;
                document.getElementById('inputWeight').value = specimen.weight;
                document.getElementById('inputHardness').value = specimen.hardness;
                document.getElementById('inputAge').value = specimen.age;
                document.getElementById('inputFormation').value = specimen.formation;
                document.getElementById('inputLocality').value = specimen.locality;
                document.getElementById('inputImage').value = specimen.img;
                document.getElementById('inputDesc').value = specimen.desc;
            } else {
                editingSpecimenId = null;
                modalTitle.textContent = 'Agregar muestra al catálogo';
                saveBtn.textContent = 'Guardar muestra';
                addForm.reset();
                document.getElementById('inputImage').value = 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=900';
            }

            modalBackdrop.classList.remove('hidden');
            if (pageHeader) pageHeader.classList.add('hidden');
            document.body.classList.add('overflow-hidden');
        }

        function saveRecord(event) {
            event.preventDefault();
            const savedSpecimen = {
                id: editingSpecimenId || Date.now(),
                code: document.getElementById('inputCode').value.trim() || `AUTO-${Date.now()}`,
                name: document.getElementById('inputName').value.trim(),
                category: document.getElementById('inputCategory').value,
                type: document.getElementById('inputType').value,
                color: document.getElementById('inputColor').value.trim() || 'Sin dato',
                size: document.getElementById('inputSize').value.trim() || 'Sin dato',
                weight: document.getElementById('inputWeight').value.trim() || 'Sin dato',
                hardness: document.getElementById('inputHardness').value.trim() || 'Sin dato',
                locality: document.getElementById('inputLocality').value.trim() || 'Sin dato',
                age: document.getElementById('inputAge').value.trim() || 'Sin dato',
                formation: document.getElementById('inputFormation').value.trim() || 'Sin dato',
                habitat: 'Registro agregado por usuario',
                desc: document.getElementById('inputDesc').value.trim() || 'Sin descripción',
                img: document.getElementById('inputImage').value.trim() || 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=900'
            };

            if (editingSpecimenId) {
                const index = dataset.findIndex(item => item.id === editingSpecimenId);
                if (index !== -1) {
                    dataset[index] = savedSpecimen;
                }
            } else {
                dataset.unshift(savedSpecimen);
            }

            saveDataset();
            closeModal();
            filterData();
            showSpecimen(savedSpecimen.id);
        }

        function openEditModal(id, event) {
            if (event) event.stopPropagation();
            const specimen = dataset.find(item => item.id === id);
            if (!specimen) return;
            openModal(specimen);
        }

        function deleteSpecimen(id, event) {
            if (event) event.stopPropagation();
            if (!confirm('¿Deseas eliminar este registro?')) return;
            const index = dataset.findIndex(item => item.id === id);
            if (index === -1) return;
            dataset.splice(index, 1);
            if (selectedSpecimenId === id) {
                selectedSpecimenId = dataset.length ? dataset[0].id : null;
            }
            saveDataset();
            filterData();
        }

        openAddBtn.addEventListener('click', () => openModal(null));
        closeModalBtn.addEventListener('click', closeModal);
        cancelAddBtn.addEventListener('click', closeModal);
        addForm.addEventListener('submit', saveRecord);
        mainSearch.addEventListener('input', filterData);
        typeFilter.addEventListener('change', filterData);
        categoryFilter.addEventListener('change', filterData);
        colorFilter.addEventListener('input', filterData);
        ageFilter.addEventListener('input', filterData);
        sortFilter.addEventListener('change', filterData);
        clearFiltersBtn.addEventListener('click', clearFilters);
        exportBtn.addEventListener('click', exportData);
        importBtn.addEventListener('click', importData);
        importFileInput.addEventListener('change', handleImportFile);
        resetBtn.addEventListener('click', resetCatalog);
        themeToggleBtn.addEventListener('click', toggleTheme);
        toggleViewBtn.addEventListener('click', () => {
            currentView = currentView === 'cards' ? 'table' : 'cards';
            updateView();
        });

        applyTheme();
        filterData();
        if (selectedSpecimenId) {
            const specimen = dataset.find(item => item.id === selectedSpecimenId);
            setDetail(specimen);
        }
    </script>
</body>
</html>
